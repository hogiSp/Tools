{
  "id": "/Tools/SpotIt_Generator/",
  "name": "Spot-It Card Generator",
  "short_name": "SpotIt",
  "description": "Create custom Spot-It match cards with your own images.",
  "start_url": "https://hogisp.github.io/Tools/SpotIt_Generator/spotit_generator.html",
